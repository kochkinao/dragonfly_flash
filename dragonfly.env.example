# Copy to dragonfly.env and fill real values.
DRAGONFLY_ACCESS_TOKEN=
# Preferred long-term auth: export browser/session cookies in Mozilla/Netscape format.
# If this file is set, cookie auth is used instead of legacy JWT.
DRAGONFLY_COOKIE_FILE=/path/to/dragonfly_cookies.txt
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=@dragonfly_flash
TELEGRAM_ALERT_CHAT_ID=
